{
    "name": "afuhy-api",
    "version": "1.1.8",
    "main": "dist/main/bootstrap/server.js",
    "scripts": {
        "dev": "cross-env NODE_ENV=development tsx watch src/main/bootstrap/server.ts",
        "qa": "cross-env NODE_ENV=qa tsx watch src/main/bootstrap/server.ts",
        "build": "tsc -p tsconfig.json && node scripts/copy-runtime-assets.mjs",
        "start": "cross-env NODE_ENV=production node dist/main/bootstrap/server.js",
        "start:dev": "cross-env NODE_ENV=development node dist/main/bootstrap/server.js",
        "start:prod": "cross-env NODE_ENV=production node dist/main/bootstrap/server.js",
        "worker:email": "tsx src/main/workers/email-worker.ts",
        "worker:email:prod": "node dist/main/workers/email-worker.js",
        "email:dev": "email dev --dir src/shared/infrastructure/email/templates --port 3001",
        "email:export": "email export --dir src/shared/infrastructure/email/templates",
        "db:migrate": "cross-env NODE_ENV=production sequelize-cli db:migrate",
        "migration:run": "NODE_ENV=production sequelize-cli db:migrate --config dist/sequelize.config.cjs --migrations-path dist/database/migrations",
        "db:migrate:dev": "cross-env NODE_ENV=development sequelize-cli db:migrate",
        "db:migrate:status": "sequelize-cli db:migrate:status",
        "db:migrate:undo": "sequelize-cli db:migrate:undo",
        "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all",
        "db:migration:generate": "sequelize-cli migration:generate",
        "db:seed:generate": "sequelize-cli seed:generate",
        "db:seed:all": "sequelize-cli db:seed:all",
        "db:seed:undo:all": "sequelize-cli db:seed:undo:all",
        "format": "prettier --write \"{src,database}/**/*.{ts,tsx,js,json,md}\" \"scripts/**/*.mjs\" \".github/workflows/*.{yml,yaml}\" \"*.{js,json,md}\"",
        "format:check": "prettier --check \"{src,database}/**/*.{ts,tsx,js,json,md}\" \"scripts/**/*.mjs\" \".github/workflows/*.{yml,yaml}\" \"*.{js,json,md}\"",
        "lint": "npm run format:check && npm run typecheck",
        "typecheck": "tsc --noEmit",
        "test": "jest --config jest.config.cjs",
        "test:watch": "jest --config jest.config.cjs --watch",
        "test:coverage": "jest --config jest.config.cjs --coverage",
        "test:e2e": "jest --config jest.e2e.config.cjs --passWithNoTests",
        "release:hml": "node scripts/release.mjs hml",
        "release:prd": "node scripts/release.mjs prd"
    },
    "devDependencies": {
        "@react-email/ui": "^6.6.7",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/supertest": "^7.2.0",
        "@types/swagger-ui-express": "^4.1.8",
        "cross-env": "^10.1.0",
        "jest": "^30.4.2",
        "prettier": "^3.8.4",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "tsx": "^4.22.4",
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "@react-email/components": "^1.0.12",
        "@react-email/render": "^2.0.10",
        "bcrypt": "^6.0.0",
        "bullmq": "^5.79.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "ioredis": "^5.11.1",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.16.3",
        "pg-hstore": "^2.3.4",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-email": "^6.6.7",
        "resend": "^6.17.1",
        "sequelize": "^6.37.8",
        "sequelize-cli": "^6.6.5",
        "stripe": "^22.3.0",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.3.6"
    }
}
